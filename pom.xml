<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
         http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>com.paymentpipeline</groupId>
    <artifactId>payment-pipeline</artifactId>
    <version>1.0.0-SNAPSHOT</version>
    <packaging>pom</packaging>

    <modules>
        <module>shared</module>
        <module>payment-service</module>
        <module>outbox-relay</module>
        <module>consumer-stubs</module>
    </modules>

    <parent>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-starter-parent</artifactId>
        <version>3.3.4</version>
        <relativePath/>
    </parent>

    <properties>
        <java.version>21</java.version>
        <avro.version>1.11.3</avro.version>
        <kafka.avro.serializer.version>7.6.0</kafka.avro.serializer.version>
        <testcontainers.version>1.20.6</testcontainers.version>
        <!--
            Docker Desktop 29.x requires a minimum API version of 1.40.
            Testcontainers' shaded docker-java defaults to 1.32 and reads its api
            version from the "api.version" Java system property (not DOCKER_API_VERSION).
            Spring Boot parent pom passes @{argLine} into Surefire's JVM args, so
            setting argLine here ensures every module's test JVM gets the override.
        -->
        <argLine>-Dapi.version=1.41 -Dnet.bytebuddy.experimental=true</argLine>
    </properties>

    <dependencyManagement>
        <dependencies>
            <!-- Internal modules -->
            <dependency>
                <groupId>com.paymentpipeline</groupId>
                <artifactId>shared</artifactId>
                <version>${project.version}</version>
            </dependency>

            <!-- Avro -->
            <dependency>
                <groupId>org.apache.avro</groupId>
                <artifactId>avro</artifactId>
                <version>${avro.version}</version>
            </dependency>

            <!-- Confluent Schema Registry -->
            <dependency>
                <groupId>io.confluent</groupId>
                <artifactId>kafka-avro-serializer</artifactId>
                <version>${kafka.avro.serializer.version}</version>
            </dependency>

            <!-- Testcontainers BOM -->
            <dependency>
                <groupId>org.testcontainers</groupId>
                <artifactId>testcontainers-bom</artifactId>
                <version>${testcontainers.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>
        </dependencies>
    </dependencyManagement>

    <build>
        <pluginManagement>
            <plugins>
                <plugin>
                    <groupId>org.apache.maven.plugins</groupId>
                    <artifactId>maven-surefire-plugin</artifactId>
                    <configuration>
                        <!--
                            Docker Desktop 29.x dropped support for API versions below 1.40.
                            docker-java defaults to requesting an older version, so we pin it
                            here so the env var is visible to every module's forked test JVM.
                        -->
                        <environmentVariables>
                            <DOCKER_API_VERSION>1.41</DOCKER_API_VERSION>
                            <DOCKER_HOST>unix:///var/run/docker.sock</DOCKER_HOST>
                        </environmentVariables>
                    </configuration>
                </plugin>
            </plugins>
        </pluginManagement>
    </build>

    <repositories>
        <!-- Required for Confluent artifacts -->
        <repository>
            <id>confluent</id>
            <url>https://packages.confluent.io/maven/</url>
        </repository>
    </repositories>
</project>